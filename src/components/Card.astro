---
const { titulo, descripcion, imagen } = Astro.props;
---

<div class="card">
  {imagen && <img src={imagen} alt={titulo} class="card-img" />}

  <div class="card-body">
    <h3>{titulo}</h3>

    {descripcion && <p>{descripcion}</p>}

    <div class="extra">
      <slot />
    </div>
  </div>
</div>

<style>
.card {
  border-radius: 16px;
  overflow: hidden;
  background: white;
  box-shadow: 0 10px 25px rgba(0,0,0,0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card:hover {
  transform: translateY(-5px);
  box-shadow: 0 15px 35px rgba(0,0,0,0.12);
}

.card-img {
  width: 100%;
  height: 180px;
  object-fit: cover;
}

.card-body {
  padding: 16px;
}

.card-body h3 {
  margin-bottom: 8px;
}

.card-body p {
  color: #555;
  font-size: 14px;
}

.extra {
  margin-top: 12px;
}
</style>
---
import Card from './Card.astro';
---

<h2>Servicios enfocados en rendimiento y resultados</h2>
<p>
  Desarrollo sitios web estáticos rápidos, seguros y optimizados para convertir visitantes en clientes.
</p>

<section class="servicios">
  <Card 
  titulo="Landing Pages"
  descripcion="Diseño de páginas enfocadas en convertir visitantes en clientes"
  >
  <ul>
    <li>⚡ Carga ultra rápida</li>
    <li>📱 Diseño responsive</li>
    <li>🚀 Optimización SEO básica</li>
  </ul>

  <a slot="acciones" href="#" class="btn">Solicitar</a>
  </Card>

  <Card 
  titulo="Sitios Web Estáticos"
  descripcion="Webs modernas sin backend, seguras y de alto rendimiento"
  >
  <ul>
    <li>🔒 Mayor seguridad (sin base de datos)</li>
    <li>⚡ Velocidad superior</li>
    <li>💰 Menor costo de mantenimiento</li>
  </ul>

  <a slot="acciones" href="#" class="btn">Solicitar</a>
  </Card>

  <Card 
  titulo="Web Corporativa"
  descripcion="Presencia profesional para tu negocio en internet"
  >
  <ul>
    <li>🎯 Enfoque en marca</li>
    <li>📈 Escalable</li>
    <li>🌐 Lista para producción</li>
  </ul>

  <a slot="acciones" href="#" class="btn">Solicitar</a>
  </Card>
</section>

<style>
.servicios {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
}
</style>
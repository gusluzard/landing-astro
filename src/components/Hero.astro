<style>
.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 120px 10%;
  background: linear-gradient(135deg, #0f172a, #1e293b);
  color: white;
  gap: 40px;
  flex-wrap: wrap;
}

.badge {
  background: linear-gradient(90deg, #7c3aed20, #22d3ee20);
  color: #c4b5fd;
  display: inline-block;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 0.9rem;
  margin-bottom: 15px;
}

.hero-text {
  max-width: 480px;
}

.hero-text h1 {
  font-family: 'Playfair Display', serif;
  font-size: 3rem;
  margin-bottom: 20px;
}

.hero-text p {
  opacity: 0.7;
  margin-bottom: 30px;
}

.hero-image {
  border-radius: 16px;
  display: inline-block;
  position: relative;
}
.hero-image img {
  width: 100%;
  max-width: 600px;
  height: auto;
  display: block;
  border-radius: 12px;
  box-shadow: 
    0 40px 80px rgba(0,0,0,0.6),
    0 10px 20px rgba(0,0,0,0.3);
  transform: perspective(1000px) rotateY(-8deg) rotateX(3deg);
  animation: float 5s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0px) rotateY(-8deg); }
  50% { transform: translateY(-10px) rotateY(-8deg); }
  100% { transform: translateY(0px) rotateY(-8deg); }
}

.hero-image {
  position: relative;
}

.hero-image::before {
  content: "";
  position: absolute;
  width: 140%;
  height: 140%;
  background: radial-gradient(circle, #22c55e22, transparent 70%);
  top: -20%;
  left: -20%;
  z-index: -1;
}

</style>

<section class="hero">
  <div class="hero-text">
    <p class="badge">Diseño web para negocios</p>
    <h1>Consigue más clientes con una web que vende por ti</h1>
    <p>Landing pages rápidas, modernas y optimizadas para convertir visitas en clientes</p>
    <a href="#" class="btn">Solicitar presupuesto</a>
  </div>

  <div class="hero-image">
  <img src="/src/images/mockup.jpg" alt="Preview web" />
  </div>

<p style="opacity:0.7; margin-top:10px;">
  Más de 10 negocios ya confían en mis servicios
</p>
</section>

<style>
.hero {
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: "";
  position: absolute;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(37,99,235,0.15), transparent 70%);
  top: 20%;
  left: 10%;
  filter: blur(80px);
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 120px 10%;
  background: var(--bg-primary);
  color: var(--text-primary);
  gap: 60px;
  flex-wrap: wrap;
}

/* texto */
.hero-text {
  max-width: 520px;
}

.hero-text h1 {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 3rem;
  margin-bottom: 20px;
  line-height: 1.2;
}

.hero-text p {
  color: var(--text-secondary);
  margin-bottom: 30px;
}

/* badge */
.badge {
  font-size: 0.85rem;
  color: var(--accent);
  margin-bottom: 15px;
}

/* botones */
.hero-buttons {
  display: flex;
  gap: 15px;
}

.btn-primary {
  background: linear-gradient(135deg, #2563EB, #3B82F6);
  color: white;
  padding: 14px 26px;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow:
    0 10px 20px rgba(37, 99, 235, 0.3),
    0 0 20px rgba(37, 99, 235, 0.4);
}

.btn-secondary {
  border: 1px solid var(--border);
  padding: 14px 26px;
  border-radius: 8px;
  color: var(--text-primary);
  text-decoration: none;
  transition: all 0.3s ease;
}

.btn-secondary:hover {
  border-color: #2563EB;
  color: #2563EB;
}

.trust {
  margin-top: 20px;
  font-size: 0.9rem;
  color: var(--text-secondary);
}

/* imagen */
.hero-image img {
  max-width: 520px;
  border-radius: 12px;
}
</style>

<section class="hero">

  <div class="hero-text">
    <p class="badge">NexByte</p>

    <h1>
      Consigue más clientes con una web que vende por ti
    </h1>

    <p>
      Diseño páginas rápidas, modernas y optimizadas para que tu negocio venda más desde internet.
    </p>

    <div class="hero-buttons">
      <a href="#" class="btn-primary">Cotizar</a>
      <a href="#" class="btn-secondary">Ver servicios</a>
    </div>

    <p class="trust">
    ⚡ Rápido • 💻 Profesional • 🚀 Enfocado en ventas
    </p>
    
  </div>

  <div class="hero-image">
    <img src="/src/images/mockup.jpg" alt="Preview NexByte" />
  </div>

</section>